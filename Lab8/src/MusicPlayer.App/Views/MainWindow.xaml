<Window x:Class="MusicPlayer.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MusicPlayer.App.ViewModels"
        xmlns:conv="clr-namespace:MusicPlayer.App.Converters"
        Title="Music Player"
        Width="980"
        Height="680"
        MinWidth="860"
        MinHeight="600"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}">
  <Window.DataContext>
    <vm:MainWindowViewModel/>
  </Window.DataContext>
  <Window.InputBindings>
    <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}"/>
    <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}"/>
  </Window.InputBindings>
  <Window.Resources>
    <conv:DurationConverter x:Key="DurationConverter"/>
    <conv:StrategyRadioConverter x:Key="StrategyRadioConverter"/>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
      <DockPanel>
        <TextBlock Text="🎵 Music Player" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
          <Button Content="↶ Undo" Command="{Binding UndoCommand}" IsEnabled="{Binding CanUndo}"/>
          <Button Content="↷ Redo" Command="{Binding RedoCommand}" IsEnabled="{Binding CanRedo}"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Grid.Row="1" Margin="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Margin="0,0,6,0">
        <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
          <DockPanel LastChildFill="True">
            <TextBlock Text="{Binding TrackCountLabel}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" DockPanel.Dock="Top"/>
            <Button Content="+ Add Files…" Command="{Binding AddFilesCommand}" DockPanel.Dock="Bottom" Margin="0,8,0,0"/>
            <ListView ItemsSource="{Binding Tracks}" SelectedItem="{Binding SelectedTrack}" Background="Transparent" BorderThickness="0" Height="260">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="#" Width="28">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock HorizontalAlignment="Center"/>
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                  <GridViewColumn Header="Title" Width="230">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock TextTrimming="CharacterEllipsis">
                          <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} — {1}">
                              <Binding Path="Title"/>
                              <Binding Path="Artist"/>
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                  <GridViewColumn Header="Time" Width="48">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Duration, Converter={StaticResource DurationConverter}}" HorizontalAlignment="Right"/>
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                </GridView>
              </ListView.View>
            </ListView>
          </DockPanel>
        </Border>

        <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
          <StackPanel>
            <TextBlock Text="PLAYBACK MODE" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
            <RadioButton Content="Sequential" GroupName="PlaybackMode" Margin="0,2"
                         IsChecked="{Binding SelectedStrategyName, Converter={StaticResource StrategyRadioConverter}, ConverterParameter=Sequential, Mode=TwoWay}"/>
            <RadioButton Content="Shuffle" GroupName="PlaybackMode" Margin="0,2"
                         IsChecked="{Binding SelectedStrategyName, Converter={StaticResource StrategyRadioConverter}, ConverterParameter=Shuffle, Mode=TwoWay}"/>
            <RadioButton Content="Smart Shuffle" GroupName="PlaybackMode" Margin="0,2"
                         IsChecked="{Binding SelectedStrategyName, Converter={StaticResource StrategyRadioConverter}, ConverterParameter=Smart Shuffle, Mode=TwoWay}"/>
            <RadioButton Content="Repeat One" GroupName="PlaybackMode" Margin="0,2"
                         IsChecked="{Binding SelectedStrategyName, Converter={StaticResource StrategyRadioConverter}, ConverterParameter=Repeat One, Mode=TwoWay}"/>
          </StackPanel>
        </Border>

        <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
          <StackPanel>
            <TextBlock Text="STATISTICS" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
            <DockPanel Margin="0,2"><TextBlock Text="Total played" DockPanel.Dock="Left"/><TextBlock Text="{Binding TotalPlayed}" DockPanel.Dock="Right" Foreground="{StaticResource TextBrush}"/></DockPanel>
            <DockPanel Margin="0,2"><TextBlock Text="Top artist" DockPanel.Dock="Left"/><TextBlock Text="{Binding TopArtist}" DockPanel.Dock="Right" Foreground="{StaticResource TextBrush}"/></DockPanel>
            <DockPanel Margin="0,2"><TextBlock Text="Skips" DockPanel.Dock="Left"/><TextBlock Text="{Binding Skips}" DockPanel.Dock="Right" Foreground="{StaticResource TextBrush}"/></DockPanel>
          </StackPanel>
        </Border>
      </StackPanel>

      <StackPanel Grid.Column="1" Margin="6,0,0,0">
        <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,8">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="NOW PLAYING" FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>
            <Border Width="130" Height="130" CornerRadius="8" Margin="0,0,0,12">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="#1F6FEB" Offset="0"/>
                  <GradientStop Color="#BC8CFF" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
              <TextBlock Text="♪♫" FontSize="42" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
            </Border>
            <TextBlock Text="{Binding CurrentTitle}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding CurrentArtist}" FontSize="14" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            <TextBlock Text="{Binding CurrentAlbum}" FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0"/>
          </StackPanel>
        </Border>

        <Border Background="{StaticResource Bg2Brush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
          <DockPanel>
            <TextBlock Text="HISTORY" FontSize="11" FontWeight="Bold" Margin="0,0,0,8" DockPanel.Dock="Top"/>
            <Button Content="↶ Undo latest" Command="{Binding UndoHistoryItemCommand}" DockPanel.Dock="Bottom" Margin="0,8,0,0"/>
            <ListBox ItemsSource="{Binding HistoryItems}" Background="Transparent" BorderThickness="0" Height="220"/>
          </DockPanel>
        </Border>
      </StackPanel>
    </Grid>

    <Border Grid.Row="2" Background="#0D1117" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,10">
      <Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
          <Button Content="⏮" Width="36" Height="36" Command="{Binding PreviousCommand}"/>
          <Button Content="▶/⏸" Width="42" Height="42" Command="{Binding PlayPauseCommand}" Background="{StaticResource AccentBrush}"/>
          <Button Content="⏭" Width="36" Height="36" Command="{Binding NextCommand}"/>
        </StackPanel>
        <Grid Margin="140,0,140,0" VerticalAlignment="Center">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Slider Minimum="0" Maximum="{Binding DurationSeconds}" Value="{Binding PositionSeconds, Mode=TwoWay}"/>
          <DockPanel Grid.Row="1">
            <TextBlock Text="{Binding PositionLabel}" DockPanel.Dock="Left"/>
            <TextBlock Text="{Binding DurationLabel}" DockPanel.Dock="Right"/>
          </DockPanel>
        </Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Width="160">
          <TextBlock Text="🔊" Margin="0,0,8,0"/>
          <Slider Minimum="0" Maximum="100" Value="{Binding VolumePercent, Mode=TwoWay}" Width="120"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
